---
import { load } from "js-yaml";
import galleryYaml from "../data/gallery.yml?raw";

const pageTitle = "ギャラリー | アイギス・アーク";
const pageDescription = "アイギス・アークの世界観や登場人物を集めた非公式ギャラリーです。";
const shareImage = new URL("/assets/img/background.webp", Astro.site);

type GalleryItem = { src: string; tags: string[]; description?: string; position?: string };
type GalleryData = { items: GalleryItem[] };

const galleryData = load(galleryYaml) as GalleryData;
const galleryItems = galleryData.items;
const tags = [...new Set(galleryItems.flatMap((item) => item.tags))].sort((a, b) => a.localeCompare(b, "ja"));
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/assets/img/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/assets/img/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#071321" />
    <meta name="description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={shareImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{pageTitle}</title>
    <style>
      :root { color-scheme: dark; --ink:#f4f8ff; --muted:#9fb0c8; --line:rgb(255 255 255 / .14); --panel:rgb(13 26 43 / .82); --page:#071321; --accent:#74d7ff; --gold:#d8af62; --focus:#f4c86a; }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin:0; min-height:100vh; color:var(--ink); background:linear-gradient(rgb(7 19 33 / .78),rgb(7 19 33 / .97)),url("/assets/img/background.webp") center top / cover fixed,var(--page); font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; }
      body.modal-open { overflow:hidden; }
      button { font:inherit; }
      img { display:block; max-width:100%; }
      a { color:inherit; }
      .shell { width:min(1120px,calc(100% - 32px)); margin:0 auto; }
      .site-header { position:sticky; top:0; z-index:20; border-bottom:1px solid var(--line); background:rgb(7 19 33 / .82); backdrop-filter:blur(18px); }
      .header-inner { display:flex; gap:16px; align-items:center; justify-content:space-between; min-height:82px; padding-block:12px; }
      .brand { display:inline-block; text-decoration:none; }
      .brand img { width:min(230px,48vw); }
      .nav { display:flex; flex-wrap:wrap; gap:10px; justify-content:flex-end; }
      .nav a { padding:8px 10px; border:1px solid transparent; border-radius:8px; color:#dbe7f8; font-size:.84rem; font-weight:800; text-decoration:none; }
      .nav a:hover,.nav a[aria-current="page"] { border-color:rgb(116 215 255 / .42); color:#fff; background:rgb(116 215 255 / .1); }
      .hero { padding:68px 0 34px; }
      .eyebrow { display:inline-flex; gap:8px; align-items:center; margin:0 0 14px; color:var(--gold); font-size:.78rem; font-weight:900; letter-spacing:.14em; }
      .eyebrow::before { width:28px; height:1px; background:currentColor; content:""; }
      h1 { margin:0; font-size:clamp(2.7rem,9vw,5.6rem); line-height:.98; }
      h1 em { color:var(--accent); font-style:normal; }
      .lead { max-width:680px; margin:22px 0 0; color:#d5e3f5; font-size:clamp(1rem,2.4vw,1.15rem); line-height:1.9; }
      .gallery-section { padding:26px 0 72px; }
      .toolbar { position:sticky; top:82px; z-index:10; display:flex; gap:20px; align-items:center; justify-content:space-between; margin-bottom:22px; padding:14px 16px; border:1px solid var(--line); border-radius:8px; background:rgb(8 18 31 / .9); box-shadow:0 18px 50px rgb(0 0 0 / .22); backdrop-filter:blur(16px); }
      .filters,.view-switch { display:flex; flex-wrap:wrap; gap:8px; }
      .filter,.view-button { min-height:36px; padding:0 12px; border:1px solid var(--line); border-radius:6px; color:var(--muted); background:rgb(255 255 255 / .04); cursor:pointer; font-size:.76rem; font-weight:900; letter-spacing:.08em; }
      .filter:hover,.view-button:hover,.filter[aria-pressed="true"],.view-button[aria-pressed="true"] { border-color:rgb(116 215 255 / .62); color:#fff; background:rgb(116 215 255 / .14); }
      .gallery-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:16px; }
      .gallery-card { overflow:hidden; margin:0; border:1px solid var(--line); border-radius:8px; background:var(--panel); box-shadow:0 18px 50px rgb(0 0 0 / .2); transition:transform 160ms ease,border-color 160ms ease; }
      .gallery-card:hover { border-color:rgb(116 215 255 / .58); transform:translateY(-2px); }
      .gallery-card[hidden] { display:none; }
      .gallery-link { display:block; width:100%; padding:0; border:0; color:inherit; background:transparent; cursor:zoom-in; text-align:left; }
      .gallery-image { width:100%; aspect-ratio:4 / 3; object-fit:cover; object-position:var(--position); background:#0b1828; transition:transform 240ms ease; }
      .gallery-link:hover .gallery-image { transform:scale(1.02); }
      .caption { padding:15px 16px 17px; border-top:1px solid var(--line); }
      .caption-tags { display:flex; flex-wrap:wrap; gap:6px; margin:0 0 8px; }
      .caption-tag { padding:3px 7px; border:1px solid rgb(116 215 255 / .3); border-radius:999px; color:var(--accent); background:rgb(116 215 255 / .08); font-size:.68rem; font-weight:800; }
      .gallery-grid[data-view="photos"] { grid-template-columns:repeat(4,minmax(0,1fr)); gap:8px; }
      .gallery-grid[data-view="photos"] .gallery-card { border-radius:3px; }
      .gallery-grid[data-view="photos"] .gallery-image { aspect-ratio:1; }
      .gallery-grid[data-view="photos"] .caption { display:none; }
      .empty { padding:40px; border:1px solid var(--line); color:var(--muted); background:var(--panel); text-align:center; }
      .modal { position:fixed; inset:0; z-index:100; display:none; place-items:center; padding:24px; }
      .modal.is-open { display:grid; }
      .modal-backdrop { position:absolute; inset:0; background:rgb(2 8 15 / .9); backdrop-filter:blur(12px); }
      .modal-dialog { position:relative; display:grid; grid-template-columns:48px minmax(0,1fr) 48px; gap:14px; align-items:center; width:min(1080px,100%); max-height:calc(100vh - 48px); }
      .modal-figure { min-width:0; margin:0; }
      .modal-image-wrap { display:grid; place-items:center; min-height:200px; max-height:calc(100vh - 150px); border:1px solid var(--line); background:#030a12; box-shadow:0 30px 90px rgb(0 0 0 / .55); }
      .modal-image { max-width:100%; max-height:calc(100vh - 150px); object-fit:contain; }
      .modal-caption { display:grid; gap:4px; padding-top:12px; text-align:center; }
      .modal-caption span { color:var(--muted); font-size:.86rem; line-height:1.5; }
      .modal-close,.modal-nav { border:1px solid var(--line); color:#fff; background:rgb(8 18 31 / .86); cursor:pointer; }
      .modal-close { position:absolute; top:0; right:0; z-index:2; width:42px; height:42px; font-size:1.6rem; }
      .modal-nav { width:48px; height:60px; border-radius:6px; font-size:2rem; }
      .site-footer { padding:26px 0; border-top:1px solid var(--line); color:var(--muted); text-align:center; }
      :focus-visible { outline:3px solid var(--focus); outline-offset:3px; }
      @media (max-width:820px) { .header-inner { display:grid; justify-items:start; min-height:88px; padding-block:16px; } .nav { justify-content:flex-start; } .hero { padding-top:40px; } .toolbar { position:static; align-items:flex-start; flex-direction:column; gap:12px; } .gallery-grid { grid-template-columns:repeat(2,minmax(0,1fr)); } .gallery-grid[data-view="photos"] { grid-template-columns:repeat(3,minmax(0,1fr)); } }
      @media (max-width:520px) { body { background:linear-gradient(rgb(7 19 33 / .8),rgb(7 19 33 / .96)),url("/assets/img/background.webp") center 118px / 210vw auto no-repeat,var(--page); background-attachment:scroll; } .shell { width:min(100% - 24px,1120px); } .hero { padding-top:28px; } .gallery-grid { gap:10px; } .gallery-grid[data-view="photos"] { grid-template-columns:repeat(2,minmax(0,1fr)); } .caption { padding:11px; } .modal { padding:12px; } .modal-dialog { display:block; } .modal-nav { position:absolute; top:50%; z-index:2; width:42px; height:52px; transform:translateY(-50%); } .modal-prev { left:4px; } .modal-next { right:4px; } .modal-close { top:4px; right:4px; } }
      @media (prefers-reduced-motion:reduce) { * { scroll-behavior:auto !important; transition:none !important; } }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="shell header-inner">
        <a class="brand" href="/" aria-label="トップページへ戻る"><img src="/assets/img/title_logo_landscape.svg" alt="アイギス・アーク" /></a>
        <nav class="nav" aria-label="サイトナビゲーション">
          <a href="/#world">アーク世界観</a><a href="/#plots">プロット</a><a href="/gallery/" aria-current="page">ギャラリー</a><a href="/#creator">作者</a>
        </nav>
      </div>
    </header>
    <main>
      <section class="hero"><div class="shell"><p class="eyebrow">AEGIS ARC ARCHIVE</p><h1>VISUAL<br /><em>GALLERY</em></h1><p class="lead">学院の風景、執行官たちの記録、物語の断片を保管するビジュアルアーカイブです。画像を選ぶと拡大表示できます。</p></div></section>
      <section class="gallery-section"><div class="shell">
        <div class="toolbar" aria-label="ギャラリー表示設定">
          <div class="filters" role="group" aria-label="キャラクタータグで絞り込む"><button class="filter" type="button" data-filter="all" aria-pressed="true">ALL</button>{tags.map((tag) => <button class="filter" type="button" data-filter={tag} aria-pressed="false">{tag}</button>)}</div>
          <div class="view-switch" role="group" aria-label="表示方法"><button class="view-button" type="button" data-view-button="cards" aria-pressed="true">カード</button><button class="view-button" type="button" data-view-button="photos" aria-pressed="false">写真</button></div>
        </div>
        <div class="gallery-grid" data-view="cards">
          {galleryItems.map((item, index) => { const imageLabel = item.tags.length ? item.tags.join("・") : "ギャラリー画像"; return <figure class="gallery-card" data-tags={item.tags.join("|")}><button class="gallery-link" type="button" data-index={index} aria-label={`${imageLabel}の画像を拡大表示`}><img class="gallery-image" src={item.src} alt={`${imageLabel}のギャラリー画像`} loading="lazy" style={`--position:${item.position ?? "50% 50%"}`} /></button><figcaption class="caption"><div class="caption-tags">{item.tags.map((tag) => <span class="caption-tag">{tag}</span>)}</div></figcaption></figure>; })}
        </div>
        <p class="empty" hidden>このカテゴリーの画像はまだありません。</p>
      </div></section>
    </main>
    <footer class="site-footer"><div class="shell">アイギス・アーク / VISUAL ARCHIVE</div></footer>
    <div class="modal" id="gallery-modal" aria-hidden="true"><div class="modal-backdrop" data-close></div><div class="modal-dialog" role="dialog" aria-modal="true" aria-label="ギャラリー画像の拡大表示"><button class="modal-close" type="button" data-close aria-label="閉じる">×</button><button class="modal-nav modal-prev" type="button" data-prev aria-label="前の画像">‹</button><figure class="modal-figure"><div class="modal-image-wrap"><img class="modal-image" src="" alt="" /></div><figcaption class="modal-caption"><span id="modal-description"></span></figcaption></figure><button class="modal-nav modal-next" type="button" data-next aria-label="次の画像">›</button></div></div>
    <script define:vars={{ galleryItems }} is:inline>
      const grid=document.querySelector(".gallery-grid"),cards=[...document.querySelectorAll(".gallery-card")],modal=document.querySelector("#gallery-modal"),modalImage=modal.querySelector(".modal-image"),modalDescription=modal.querySelector("#modal-description"); let activeFilter="all",currentIndex=0,lastTrigger=null;
      const visibleIndices=()=>cards.map((card,index)=>card.hidden?null:index).filter((index)=>index!==null);
      function openModal(index){const item=galleryItems[index]; if(!item)return; currentIndex=index; lastTrigger=document.activeElement; modalImage.src=item.src; modalImage.alt=(item.tags.length?item.tags.join("・"):"ギャラリー")+"のギャラリー画像"; modalDescription.textContent=item.description||""; modalDescription.closest(".modal-caption").hidden=!item.description; modal.classList.add("is-open"); modal.setAttribute("aria-hidden","false"); document.body.classList.add("modal-open"); modal.querySelector(".modal-close").focus();}
      function closeModal(){modal.classList.remove("is-open"); modal.setAttribute("aria-hidden","true"); document.body.classList.remove("modal-open"); modalImage.src=""; lastTrigger?.focus();}
      function move(direction){const visible=visibleIndices(); const position=visible.indexOf(currentIndex); openModal(visible[(position+direction+visible.length)%visible.length]);}
      document.querySelectorAll("[data-filter]").forEach((button)=>button.addEventListener("click",()=>{activeFilter=button.dataset.filter; cards.forEach((card)=>{const tags=(card.dataset.tags||"").split("|"); card.hidden=activeFilter!=="all"&&!tags.includes(activeFilter);}); document.querySelectorAll("[data-filter]").forEach((item)=>item.setAttribute("aria-pressed",String(item===button))); document.querySelector(".empty").hidden=visibleIndices().length>0;}));
      document.querySelectorAll("[data-view-button]").forEach((button)=>button.addEventListener("click",()=>{grid.dataset.view=button.dataset.viewButton; document.querySelectorAll("[data-view-button]").forEach((item)=>item.setAttribute("aria-pressed",String(item===button)));}));
      document.querySelectorAll(".gallery-link").forEach((button)=>button.addEventListener("click",()=>openModal(Number(button.dataset.index))));
      modal.addEventListener("click",(event)=>{if(event.target.closest("[data-close]"))closeModal(); else if(event.target.closest("[data-prev]"))move(-1); else if(event.target.closest("[data-next]"))move(1);});
      document.addEventListener("keydown",(event)=>{if(!modal.classList.contains("is-open"))return; if(event.key==="Escape")closeModal(); if(event.key==="ArrowLeft")move(-1); if(event.key==="ArrowRight")move(1);});
    </script>
  </body>
</html>
